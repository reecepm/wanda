# Wanda environment variables. Copy to .env and adjust as needed.
# Every var here is optional; the listed value is the built-in default.

# ── Server mode ──────────────────────────────────────────────────────────────
WANDA_SERVER_MODE=embedded            # embedded | subprocess
WANDA_SERVER_ENTRY=                   # subprocess: path to compiled server.js (default out/main/server.js)
WANDA_SERVER_ID=                      # override the persisted server identity (mainly for tests)
WANDA_HEADLESS=                       # 1 = run the shell without showing a window
WANDA_SKIP_ONBOARDING=                # 1 = mark onboarding complete on startup

# ── Networking & security ────────────────────────────────────────────────────
WANDA_LISTEN_HOST=127.0.0.1           # interface the HTTP/WS server binds to
WANDA_HOST=127.0.0.1                  # standalone server bind host (server:start)
WANDA_PORT=9191                       # HTTP/WS listen port (0 = pick a free port)
WANDA_TOKEN=                          # Bearer token shared with the MCP client
WANDA_PORT_FILE=                      # path the MCP port is written to (default <data>/mcp-port)
WANDA_HANDSHAKE_STDOUT=               # 1 = emit the {host,port,token} handshake on stdout
WANDA_INSECURE_LAN=                   # 1 = allow plaintext bind on a non-loopback host (tokens travel unencrypted)
WANDA_TLS_CERT_PATH=                  # reserved: TLS cert (termination not yet wired)
WANDA_TLS_KEY_PATH=                   # reserved: TLS key (termination not yet wired)

# ── SSH (remote server target) ───────────────────────────────────────────────
WANDA_SSH_HOST=                       # host to reach a remote workspace over SSH
WANDA_SSH_PORT=                       # SSH port (default 22)
WANDA_SSH_USER=                       # SSH user (defaults to $USER)

# ── Data & paths ─────────────────────────────────────────────────────────────
WANDA_DATA_DIR=                       # base data directory (default ~/.wanda)
WANDA_USER_DATA_DIR=                  # Electron userData dir override (default = data dir)
WANDA_DB_PATH=                        # SQLite database file (default <userData>/wanda.db)
WANDA_MIGRATIONS_FOLDER=              # Drizzle migrations folder override
WANDA_APP_ROOT=                       # repo/app root (default process.cwd())
WANDA_APP_VERSION=                    # version string reported by the server (default 0.0.0)
WANDA_WORKSPACE_PATH=                 # default workspace root (default = userData dir)
WANDA_MCP_SERVER_PATH=                # path to the bundled MCP server entry

# ── Debug & testing ──────────────────────────────────────────────────────────
WANDA_DEBUG=                          # any non-empty value raises log verbosity to debug
WANDA_FAKE_RUNTIME=                   # 1 = register the in-memory fake workenv runtime adapter
WANDA_INTEGRATION=                    # 1 = run adapter integration tests (otherwise skipped)
WANDA_E2E_EXPOSE_TEST_HELPERS=        # 1 = expose window test helpers in preload (E2E only)

# ── Agent hook injection (set per terminal at runtime) ───────────────────────
WANDA_HTTP_HOST=127.0.0.1             # host agent hooks call back into
WANDA_HTTP_PORT=                      # port agent hooks call back into
WANDA_AGENT_TYPE=opencode             # agent identifier injected into hooks
WANDA_TERMINAL_ID=                    # terminal id passed to injected agent hooks

# ── Build ────────────────────────────────────────────────────────────────────
APP_CHANNEL=dev                       # release channel baked into the build (e.g. dev, stable)
