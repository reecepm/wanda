{
  "$schema": "https://biomejs.dev/schemas/2.3.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!out", "!**/*.gen.*", "!drizzle"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn",
        "noEmptyPattern": "warn",
        "noVoidTypeReturn": "warn",
        "useExhaustiveDependencies": "warn",
        "useHookAtTopLevel": "warn"
      },
      "complexity": {
        "useLiteralKeys": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "warn",
        "noAssignInExpressions": "warn",
        "noControlCharactersInRegex": "warn",
        "noDoubleEquals": "warn",
        "noExplicitAny": "off",
        "noNonNullAssertedOptionalChain": "warn",
        "useIterableCallbackReturn": "warn"
      },
      "a11y": {
        "noAutofocus": "warn",
        "noLabelWithoutControl": "off",
        "noRedundantRoles": "warn",
        "noStaticElementInteractions": "warn",
        "noSvgWithoutTitle": "warn",
        "useAriaPropsForRole": "warn",
        "useFocusableInteractive": "warn",
        "useKeyWithClickEvents": "warn",
        "useSemanticElements": "off",
        "useValidAriaRole": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["electron/router/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/repository/*", "**/repository", "**/db/schema", "**/infra/database"],
                    "message": "Routers must not import repositories or database internals directly. Use controllers."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["shared/contracts/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/electron/domains/**"],
                    "message": "Shared contracts must not import from backend domain implementation files. Move boundary types/schemas into shared/contracts."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/**", "src/pages/**", "src/layout/**", "src/stores/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/electron/**"],
                    "message": "Renderer code must not import from electron/ directly. Re-export types through src/types/schema.ts."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/**/__tests__/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
