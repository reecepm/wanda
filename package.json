{
  "name": "wanda",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./out/main/main.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run mcp:build && electron-vite dev",
    "dev:subprocess": "bun run mcp:build && WANDA_SERVER_MODE=subprocess electron-vite dev",
    "web:dev": "vite --config vite.web.config.ts",
    "web:build": "vite --config vite.web.config.ts build",
    "web:preview": "vite --config vite.web.config.ts preview",
    "build": "bun run typecheck && bun run mcp:build && electron-vite build",
    "preview": "electron-vite preview",
    "package": "bun run mcp:build && APP_CHANNEL=stable electron-vite build && electron-builder",
    "package:dev": "bun run mcp:build && APP_CHANNEL=dev electron-vite build && electron-builder -c electron-builder.dev.yml",
    "rebuild": "npx @electron/rebuild",
    "rebuild:node": "npm rebuild better-sqlite3 node-pty",
    "lint": "biome check . && bun run lint:frontend && bun run lint:backend",
    "lint:fix": "biome check --write . && bun run lint:frontend && bun run lint:backend",
    "postinstall": "npx @electron/rebuild --only better-sqlite3,node-pty",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:reset": "bun scripts/reset-db.ts",
    "onboarding:reset": "bun scripts/reset-onboarding.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "server:start": "tsx electron/server/bin.ts",
    "server:smoke": "vitest run electron/server/__tests__/standalone-smoke.test.ts",
    "test": "vitest run --project unit --project services",
    "test:integration": "WANDA_INTEGRATION=1 vitest run --project integration",
    "test:e2e": "electron-vite build && playwright test",
    "test:e2e:only": "playwright test",
    "test:e2e:quick": "electron-vite build && WANDA_HEADLESS=1 playwright test e2e/smoke.spec.ts e2e/paired-bridge-lifecycle.spec.ts e2e/paired-pod-renders.spec.ts e2e/paired-cold-boot.spec.ts e2e/paired-invalidate-predicate.spec.ts e2e/paired-preexisting-terminals.spec.ts e2e/paired-test-pod-scenario.spec.ts e2e/ui-bidirectional-terminal.spec.ts",
    "preflight": "bun run typecheck && bun run test:e2e",
    "mcp:build": "tsc -p electron/mcp/tsconfig.json",
    "typecheck": "tsgo --noEmit --project tsconfig.electron.json && tsgo --noEmit --project tsconfig.app.json && bun scripts/lint-barrel-imports.ts",
    "lint:barrels": "bun scripts/lint-barrel-imports.ts",
    "lint:frontend": "eslint src --ext .ts,.tsx && bun run frontend:lint-architecture && bun run frontend:lint-unsafe-types && bun run frontend:audit-dead-code && bun run lint:barrels",
    "frontend:lint-architecture": "bun scripts/lint-frontend-architecture.ts",
    "frontend:lint-unsafe-types": "bun scripts/lint-frontend-unsafe-types.ts",
    "frontend:audit-dead-code": "bun scripts/audit-frontend-dead-code.ts",
    "lint:backend": "bun run backend:lint-architecture && bun run backend:audit-domain-db && bun run backend:audit-dead-code",
    "backend:lint-architecture": "bun scripts/lint-backend-architecture.ts",
    "backend:audit-domain-db": "bun scripts/audit-backend-domain-db.ts",
    "backend:audit-dead-code": "bun scripts/audit-backend-dead-code.ts"
  },
  "dependencies": {
    "@ariakit/react": "^0.4.21",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openai/codex": "^0.135.0",
    "@orpc/client": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@orpc/tanstack-query": "^1.13.5",
    "@pierre/diffs": "1.1.12",
    "@platejs/autoformat": "^52.3.10",
    "@platejs/basic-nodes": "^52.0.11",
    "@platejs/code-block": "^52.3.16",
    "@platejs/combobox": "^52.0.15",
    "@platejs/link": "^52.3.17",
    "@platejs/list": "^52.3.10",
    "@platejs/markdown": "^52.3.22",
    "@platejs/slash-command": "^52.3.10",
    "@platejs/table": "^52.3.20",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/db": "^0.6.2",
    "@tanstack/query-core": "^5.96.2",
    "@tanstack/query-db-collection": "^1.0.33",
    "@tanstack/react-db": "^0.1.80",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-hotkeys": "^0.1.0",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.159.6",
    "@wanda/agent-protocol": "workspace:*",
    "@wanda/agent-providers": "workspace:*",
    "@wanda/agent-runtime": "workspace:*",
    "@wanda/agent-store": "workspace:*",
    "@wanda/agent-ui": "workspace:*",
    "@wanda/client-connection": "workspace:*",
    "@wanda/event-log": "workspace:*",
    "@wanda/gateway": "workspace:*",
    "@wanda/router": "workspace:*",
    "@wanda/session": "workspace:*",
    "@wanda/subscriptions": "workspace:*",
    "@wanda/tasks": "workspace:*",
    "@wanda/terminal-engine": "file:packages/terminal-engine",
    "@wanda/wire": "workspace:*",
    "@xterm/addon-fit": "0.12.0-beta.197",
    "@xterm/addon-serialize": "0.15.0-beta.197",
    "@xterm/addon-web-links": "0.13.0-beta.197",
    "@xterm/addon-webgl": "0.20.0-beta.196",
    "@xterm/headless": "6.1.0-beta.197",
    "@xterm/xterm": "6.1.0-beta.197",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dockerode": "^4.0.9",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.19.16",
    "effect-orpc": "^0.0.10",
    "evlog": "^2.5.0",
    "js-yaml": "^4.1.1",
    "motion": "^12.34.1",
    "node-pty": "^1.1.0",
    "platejs": "^52.0.17",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-grid-layout": "^2.2.2",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "unicode-animations": "^1.0.3",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@chromatic-com/storybook": "^5.0.1",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-onboarding": "^10.2.8",
    "@storybook/addon-vitest": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.4.0",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.2.8",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "shadcn": "^3.8.4",
    "sharp": "^0.34.5",
    "storybook": "^10.2.8",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  },
  "trustedDependencies": [
    "electron",
    "protobufjs"
  ]
}
