  "$schema": "./frontend-architecture-exceptions.schema.json",
  "lastReviewed": "2026-05-04",
  "rules": {
    "legacy-pages": {
      "owner": "frontend-cleanup",
      "justification": "No legacy page files are currently approved; this empty rule keeps the architecture check rejecting any production src/pages screen that appears later.",
      "removalCondition": "Keep this list empty. Any future entry requires an explicit temporary owner and cleanup plan.",
      "files": []
    },
    "legacy-page-imports": {
      "owner": "frontend-cleanup",
      "justification": "No production imports from deprecated page modules are currently approved; this empty rule keeps the architecture check rejecting any new proxy.",
      "removalCondition": "Keep this list empty. Any future entry requires an explicit temporary owner and cleanup plan.",
      "imports": []
    },
    "renderer-electron-imports": {
      "owner": "frontend-cleanup",
      "justification": "Approved renderer boundary files adapt the Electron preload API for browser/web entry typing.",
      "removalCondition": "Remove entries if these files stop importing preload/type boundary code from electron/.",
      "files": ["src/types/electron.d.ts", "src/web-entry.ts"]
    },
    "shared-contract-electron-router-compat": {
      "owner": "frontend-cleanup",
      "justification": "The existing router compatibility contract imports the server router type until the boundary type is generated or exported from shared/contracts.",
      "removalCondition": "Remove this entry when shared/contracts/router.ts no longer imports from electron/router.",
      "files": ["shared/contracts/router.ts"]
    },
    "raw-window-wanda": {
      "owner": "frontend-cleanup",
      "justification": "Approved renderer boundary modules that adapt the preload/native API: shared app/oRPC/outbox bridges, web bootstrap, and owning feature transports for agent sessions, agent events, server pairing, and terminals.",
      "removalCondition": "Delete an entry if its window.wanda access moves behind a narrower boundary or the native capability is replaced by shared oRPC/contracts.",
      "files": [
        "src/features/agent-session/transport.ts",
        "src/features/agent/agent-events.ts",
        "src/features/servers/use-servers.ts",
        "src/features/terminal/terminal-transport.ts",
        "src/shared/app-bridge.ts",
        "src/shared/orpc.ts",
        "src/shared/paired-client-outbox.ts",
        "src/web-entry.ts"
      ]
    },
    "direct-orpc-client": {
      "owner": "frontend-cleanup",
      "justification": "Pre-existing files import the raw oRPC client directly. New files should use feature hooks/query helpers unless explicitly documented.",
      "removalCondition": "Delete each file entry after raw orpc usage is replaced by feature hooks, orpcUtils query options, or a documented transport adapter.",
      "files": []
    },
    "unsafe-type-escapes": {
      "owner": "frontend-cleanup",
      "justification": "Pre-existing frontend files still contain explicit any, @ts-ignore/@ts-expect-error, or broad double-cast patterns. New unsafe typing files should be rejected while this list is burned down.",
      "removalCondition": "Delete each file entry after unsafe type escapes are replaced by precise types, narrowing, or documented boundary types.",
      "files": []
    },
    "bundle-split-deep-imports": {
      "owner": "bundle-audit",
      "justification": "These imports intentionally bypass cross-feature barrels because Vite/Rollup route splitting produced circular chunk warnings when lazy chunks imported modules through barrels that also re-exported their dependencies.",
